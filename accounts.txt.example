# Add your rpow2 session cookie here
# Format: rpow_session=YOUR_COOKIE_HERE
# 
# How to get your cookie:
# 1. Login to rpow2.com
# 2. Open DevTools (F12)
# 3. Go to Application → Cookies → rpow2.com
# 4. Copy the value of 'rpow_session'
# 5. Paste it below (replace this comment)

rpow_session=YOUR_COOKIE_HERE
